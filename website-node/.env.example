# Copie ce fichier en .env et remplis les valeurs reelles. Ne commite JAMAIS le .env final.

# --- MySQL (doit correspondre au bloc "mysql:" de plugins/LoyaltyMobs/config.yml) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=loyaltymobs_user
DB_PASSWORD=CHANGE_ME
DB_NAME=loyaltymobs_shop

# --- Stripe (recuperees depuis le Dashboard Stripe, en mode Test d'abord) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- URLs publiques ---
# URL publique de CE micro-service (via ton reverse-proxy), utilisee par Stripe
# pour rediriger le client apres paiement
SHOP_PUBLIC_URL=https://tonsite.fr/boutique-tickets
# URL de ton site principal, vers laquelle on redirige apres le paiement
SITE_URL=https://tonsite.fr

# --- Divers ---
PORT=3001
ORIGIN=*
# Cle utilisee pour proteger la route /admin/grant (attribution manuelle de tickets)
ADMIN_API_KEY=CHANGE_ME_AUSSI
